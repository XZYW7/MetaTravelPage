      "enabled": false,
      "language": "",
      "audio_path": "assets/audio/"
    }
  },
  "cards": [
    {
      "id": "cover",
      "type": "cover",
      "sort_index": 1,
      "title": "我的旅行指南",
      "subtitle": "请编辑 config/journey.json 自定义内容",
      "icon": "✈️"
    },
    {
      "id": "getting_started",
      "type": "reference",
      "sort_index": 90000001,
      "title": "开始使用",
      "subtitle": "快速上手指南",
      "sections": [
        {
          "type": "info_box",
          "variant": "info",
          "title": "📋 如何自定义",
          "content": "<p>编辑 <code>config/journey.json</code> 文件来定义你的旅行内容。</p><p>参考 <code>schema/journey.schema.json</code> 了解配置结构。</p><p>参考 <code>examples/thailand-travel/journey.json</code> 查看完整示例。</p>"
        },
        {
          "type": "info_box",
          "variant": "success",
          "title": "🤖 使用 AI Agent 生成",
          "content": "<p>将 <code>docs/AGENT_PROMPT.md</code> 的内容作为系统提示词，提供给 AI Agent（如 ChatGPT、Claude）。</p><p>然后提供你的旅行材料，Agent 会自动生成符合规范的 <code>journey.json</code> 配置。</p>"
        },
        {
          "type": "checklist",
          "title": "📝 配置清单",
          "items": [
            "编辑 journey.json 中的 app.title 和 app.subtitle",
            "定义 cards 数组，添加行程卡片",
            "如需短语本功能，添加音频文件到 assets/audio/",
            "如需计时器功能，在 features.timer 中配置",
            "启动服务器测试：start-server.bat"
          ]
        }
      ]
    }
  ]
}
